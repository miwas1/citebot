APP_NAME=CiteBot
APP_VERSION=0.1.0
APP_ENV=development
API_PREFIX=/api/v1
DATABASE_URL=sqlite+aiosqlite:///./citebot.db
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=citebot_chunks
ENABLE_QDRANT=false
ENABLE_PGVECTOR=false
OBJECT_STORAGE_PATH=./storage/raw_documents
SPARSE_INDEX_PATH=./storage/sparse_index.json
OPENAI_API_KEY=
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=32
CHUNK_SIZE=800
CHUNK_OVERLAP=120

