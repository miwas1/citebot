APP_NAME=CiteBot
APP_VERSION=0.1.0
APP_ENV=development
API_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://citebot:citebot@localhost:5432/citebot
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=citebot_chunks
ENABLE_QDRANT=true
ENABLE_PGVECTOR=true
OBJECT_STORAGE_PATH=./storage/raw_documents
SPARSE_INDEX_PATH=./storage/sparse_index.json
OPENAI_API_KEY=
GEMINI_API_KEY=
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
ANSWER_PROVIDER=gemini
ANSWER_MODEL=gemini-3-flash-preview
GEMINI_ANSWER_MODEL=gemini-3-flash-preview
TAVILY_API_KEY=
EVALUATION_EVALUATOR_PROVIDER=gemini
EVALUATION_EVALUATOR_MODEL=gemini-3-flash-preview
EMBEDDING_DIMENSION=32
CHUNK_SIZE=800
CHUNK_OVERLAP=120

